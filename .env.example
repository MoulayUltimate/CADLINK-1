# ── Mollie Payment Gateway ───────────────────────────────────────────────────
# Server-side secret API key (test_* or live_*)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public Mollie profile id — INLINED AT BUILD TIME by Next.js.
# On Cloudflare Pages, set this in the BUILD environment variables, then redeploy.
NEXT_PUBLIC_MOLLIE_PROFILE_ID=pfl_xxxxxxxxxxxxxxxxx

# Must be 'true' only when using a test profile + test API key.
# Set to 'false' (or remove) when deploying with a live key.
NEXT_PUBLIC_MOLLIE_TEST_MODE=true

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me

# ── Google Analytics 4 (server-side reporting) ───────────────────────────────
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Google Merchant Center ───────────────────────────────────────────────────
GOOGLE_MERCHANT_ID=
MERCHANT_SYNC_SECRET=

# ── Resend (abandoned-cart recovery emails) ──────────────────────────────────
RESEND_API_KEY=
